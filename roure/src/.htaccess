<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block /dashboard/ only on the marketing host (dashboard.* uses public_html/dashboard/ as docroot)
  RewriteCond %{HTTP_HOST} ^(www\.)?rourepersonaltraining\.nl$ [NC]
  RewriteRule ^dashboard(?:/|$) / [R=302,L]

  # CMS API paths — before filesystem short-circuit (api/ and staging-api/ are real directories)
  RewriteRule ^api(?:/.*)?$ api/index.php [L,QSA]
  RewriteRule ^staging-api(?:/.*)?$ staging-api/index.php [L,QSA]

  # Serve existing files/directories as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # CMS + uploads on same host as the public site (no /api prefix)
  RewriteRule ^content\.json$ api/index.php [L,QSA]
  RewriteRule ^content$ api/index.php [L,QSA]
  RewriteRule ^preview/ api/index.php [L,QSA]
  RewriteCond %{REQUEST_URI} ^/uploads/
  RewriteRule ^ api/index.php [L,QSA]
  RewriteCond %{REQUEST_URI} ^/admin/
  RewriteRule ^ api/index.php [L,QSA]

  # Angular SPA fallback (redirect 404s to index.html)
  RewriteRule ^ index.html [L]
</IfModule>


# Cache control
# - index.html (app shell) must NOT be cached so new deployments are picked up immediately
# - JS/CSS can be cached long-term because Angular builds them with hashes (outputHashing=all)
# - Other assets are revalidated to avoid "stale" icons/images after a deploy
<IfModule mod_headers.c>
  # Always fetch latest app shell / HTML
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Never cache JSON (content/config can change without filename changes)
  <FilesMatch "\.(json)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Cache-busted bundles (hashed filenames) - safe to cache "forever"
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Static assets (often not hashed) - allow caching but force revalidation
  <FilesMatch "\.(ico|png|jpg|jpeg|gif|webp|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>


